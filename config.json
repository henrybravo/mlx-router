{
    "defaults": {
      "max_tokens": 16384,
      "timeout": 120,
      "cache_size": 2,
      "memory_threshold_gb": 5.0,
      "safety_margin": 0.9,
      "swap_critical_percent": 99.0,
      "swap_high_percent": 90.0,
      "stream": true,
      "stream_chunk_size": 8,
      "streaming_format": "sse",
      "warmup_tokens": 5,
      "enable_function_calling": true,
      "model_directory": "/Users/username/models"
    },
    "server": {
        "ip": "0.0.0.0",
        "port": 8800,
        "debug": false
    },
    "models": {}
}
